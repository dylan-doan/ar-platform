# Owner/migration connection (Alembic + seed run as this user)
DATABASE_URL=postgresql+asyncpg://zoustec:zoustec_dev_password@localhost:5433/zoustec
# Runtime connection — RLS-restricted role created by migration 0001
APP_DATABASE_URL=postgresql+asyncpg://zoustec_app:zoustec_app_password@localhost:5433/zoustec

# Session JWT (spec §5.6). Change in production; keep out of VCS.
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_MINUTES=1440

# LINE OIDC — the platform LINE Login channel ID (Phase 1: single channel)
LINE_CHANNEL_ID=

# Dev mode: accept `dev::{line_user_id}::{name}` id_tokens. NEVER in production.
AUTH_DEV_MODE=true

CORS_ORIGINS=http://localhost:3000
